# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Pool Distribution Wallet ────────────────────────────────────────────────
# 12-word BIP39 seed phrase for the "house" wallet that sends USDT payouts.
# 1. Open /wallet, create a new wallet, copy the seed phrase here.
# 2. Copy the derived address.
# 3. Fund it with Sepolia USDT:
#    - Get Sepolia ETH: https://faucets.chain.link/sepolia
#    - Get Sepolia USDT: https://faucet.circle.com (select Ethereum Sepolia)
POOL_MASTER_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ── Demo Seeding ─────────────────────────────────────────────────────────────
# Set to "true" to enable POST /api/seed in any environment
SEED_ENABLED=false
